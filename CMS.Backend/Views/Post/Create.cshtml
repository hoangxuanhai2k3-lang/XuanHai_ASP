@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<style>
    .ck-editor {
        width: 100%;
    }

    .ck-editor__editable {
        min-height: 220px;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white fw-bold fs-4">
            <i class="bi bi-file-earmark-plus"></i>
            THÊM BÀI VIẾT MỚI
        </div>

        <div class="card-body">
            <form asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="row">
                    <div class="col-md-8">

                        <div class="mb-3">
                            <label asp-for="Title"
                                   class="form-label fw-bold">
                                Tiêu đề bài viết:
                            </label>

                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Nhập tiêu đề..." />

                            <span asp-validation-for="Title"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content"
                                   class="form-label fw-bold">
                                Nội dung chi tiết:
                            </label>
                            <textarea asp-for="Content"
                                      id="postContent"
                                      class="form-control"
                                      placeholder="Viết nội dung tại đây..."></textarea>

                            <span asp-validation-for="Content"
                                  class="text-danger">
                            </span>
                        </div>
                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">
                            <label asp-for="CategoryId"
                                   class="form-label fw-bold">
                                Chuyên mục:
                            </label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.CategoryList"
                                    class="form-select">
                                <option value="">
                                    -- Chọn danh mục --
                                </option>
                            </select>

                            <span asp-validation-for="CategoryId"
                                  class="text-danger">
                            </span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Tải ảnh đại diện:
                            </label>

                            <input type="file"
                                   name="uploadImage"
                                   class="form-control"
                                   accept="image/*" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="CreatedDate"
                                   class="form-label fw-bold">
                                Ngày đăng:
                            </label>

                            <input asp-for="CreatedDate"
                                   type="date"
                                   class="form-control" />

                            <span asp-validation-for="CreatedDate"
                                  class="text-danger">
                            </span>
                        </div>

                        <hr />

                        <button type="submit"
                                class="btn btn-success w-100 mb-2">
                            <i class="bi bi-cloud-upload"></i>
                            Lưu và Đăng bài
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary w-100">
                            Quay lại danh sách
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdn.ckeditor.com/ckeditor5/41.3.0/classic/ckeditor.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const editorElement =
        document.getElementById("postContent");

        if (!editorElement) {
        console.error(
        "Không tìm thấy ô #postContent."
        );
        return;
        }

        if (typeof ClassicEditor === "undefined") {
        console.error(
        "Không tải được thư viện CKEditor."
        );
        return;
        }

        ClassicEditor
        .create(editorElement, {
        toolbar: [
        "heading",
        "|",
        "bold",
        "italic",
        "link",
        "bulletedList",
        "numberedList",
        "|",
        "blockQuote",
        "undo",
        "redo"
        ]
        })
        .then(function (editor) {
        console.log(
        "CKEditor đã khởi tạo thành công."
        );
        })
        .catch(function (error) {
        console.error(
        "Lỗi khởi tạo CKEditor:",
        error
        );
        });
        });
    </script>
}