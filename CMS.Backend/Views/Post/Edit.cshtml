@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Sửa bài viết";
    Layout = "_LayoutAdmin";
}

<div class="card shadow">
    <div class="card-header bg-warning">
        <h4 class="mb-0">
            <i class="bi bi-pencil-square"></i> SỬA BÀI VIẾT
        </h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                        <input asp-for="Title" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung chi tiết:</label>
                        <textarea asp-for="Content" class="form-control" rows="10" required></textarea>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chuyên mục:</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                            <option value="">-- Chọn danh mục --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ảnh hiện tại:</label>
                        <br />
                        <img src="@Model.ImageUrl"
                             width="180"
                             height="120"
                             style="object-fit:cover;"
                             onerror="this.src='/images/no-image.png'" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tải ảnh đại diện mới:</label>
                        <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngày đăng:</label>
                        <input asp-for="CreatedDate" type="date" class="form-control" />
                    </div>

                    <hr />

                    <button type="submit" class="btn btn-warning w-100 mb-2">
                        <i class="bi bi-save"></i> Cập nhật bài viết
                    </button>

                    <a asp-action="Index" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>