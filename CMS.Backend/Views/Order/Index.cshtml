@model IEnumerable<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Đơn hàng";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>DANH SÁCH ĐƠN HÀNG</h2>

</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ngày đặt</th>
            <th>Khách hàng</th>
            <th>Trạng thái</th>
            <th>Ghi chú</th>
            <th style="width: 220px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            string statusText = item.Status switch
            {
                0 => "Chờ duyệt",
                1 => "Đang giao",
                2 => "Đã xong",
                _ => "Không rõ"
            };

            <tr>
                <td>@item.Id</td>
                <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.Customer?.FullName</td>
                <td>@statusText</td>
                <td>@item.Notes</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                        Xem
                    </a>

                    @if (item.Status == 0)
                    {
                        <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                            Duyệt
                        </a>
                    }

                    @if (item.Status == 1)
                    {
                        <a asp-action="Complete" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                            Hoàn thành
                        </a>
                    }

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>