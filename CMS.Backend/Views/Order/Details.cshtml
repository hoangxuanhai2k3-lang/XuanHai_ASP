@model CMS.Data.Entities.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_LayoutAdmin";
}

<h2>CHI TIẾT ĐƠN HÀNG</h2>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Ngày đặt</th>
        <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
    </tr>
    <tr>
        <th>Khách hàng</th>
        <td>@Model.Customer?.FullName</td>
    </tr>
    <tr>
        <th>Trạng thái</th>
        <td>@Model.Status</td>
    </tr>
    <tr>
        <th>Ghi chú</th>
        <td>@Model.Notes</td>
    </tr>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>