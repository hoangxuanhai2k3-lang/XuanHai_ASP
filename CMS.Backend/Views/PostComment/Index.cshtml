@model IEnumerable<CMS.Data.Entities.PostComment>

@{
    ViewData["Title"] = "Bình luận bài viết";
    Layout = "_LayoutAdmin";
}

<h2>BÌNH LUẬN BÀI VIẾT</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Bài viết</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Nội dung</th>
            <th>Ngày gửi</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Post?.Title</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Content</td>
                <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @if (item.IsApproved)
                    {
                        <span class="badge bg-success">Đã duyệt</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                    }
                </td>
                <td>
                    <a asp-action="Approve" asp-route-id="@item.Id" class="btn btn-success btn-sm">
                        Duyệt
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>