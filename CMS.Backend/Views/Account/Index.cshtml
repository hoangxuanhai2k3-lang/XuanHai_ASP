@model IEnumerable<CMS.Data.Entities.Contact>

@{
    ViewData["Title"] = "Liên hệ khách hàng";
    Layout = "_LayoutAdmin";
}

<h2>LIÊN HỆ KHÁCH HÀNG</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Nội dung</th>
            <th>Ngày gửi</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FullName</td>
                <td>@item.Email</td>
                <td>@item.Message</td>
                <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @if (item.IsRead)
                    {
                        <span class="badge bg-success">Đã đọc</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa đọc</span>
                    }
                </td>
                <td>
                    <a asp-action="MarkRead" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                        Đánh dấu đã đọc
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>