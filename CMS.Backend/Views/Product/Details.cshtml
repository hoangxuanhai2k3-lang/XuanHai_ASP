@model CMS.Data.Entities.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    Layout = "_LayoutAdmin";
}

<h2>CHI TIẾT SẢN PHẨM</h2>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Ảnh</th>
        <td>
            <img src="@Model.ImageUrl" width="120" height="120" style="object-fit:cover;" />
        </td>
    </tr>
    <tr>
        <th>Tên sản phẩm</th>
        <td>@Model.Name</td>
    </tr>
    <tr>
        <th>Mô tả</th>
        <td>@Model.Description</td>
    </tr>
    <tr>
        <th>Giá</th>
        <td>@Model.Price.ToString("N0") đ</td>
    </tr>
    <tr>
        <th>Tồn kho</th>
        <td>@Model.StockQuantity</td>
    </tr>
    <tr>
        <th>Danh mục</th>
        <td>@Model.CategoryProduct?.Name</td>
    </tr>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sửa</a>
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>