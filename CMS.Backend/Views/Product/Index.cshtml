@model IEnumerable<CMS.Data.Entities.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>DANH SÁCH SẢN PHẨM</h2>

    <a asp-action="Create" class="btn btn-success">
        + Thêm sản phẩm mới
    </a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Danh mục</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>
                    <img src="@item.ImageUrl" width="90" height="70" style="object-fit:cover;" />
                </td>
                <td>@item.Name</td>
                <td>@item.Price.ToString("N0") đ</td>
                <td>@item.StockQuantity</td>
                <td>@item.CategoryProduct?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                        Chi tiết
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>